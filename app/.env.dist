# Path to the Android SDK. Only needed when building native Android locally.
# Mac default: /Users/<you>/Library/Android/sdk
# Linux default: /home/<you>/Android/Sdk
# Windows default: C:\Users\<you>\AppData\Local\Android\Sdk
# ANDROID_SDK_ROOT=

# Local
# On an Android emulator, localhost points to the emulator itself.
# Run `yarn reverse:all-ports` (adb reverse) to forward these to the host,
# or replace localhost with 10.0.2.2 for the emulator host alias.
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
EXPO_PUBLIC_API_BASE_CMS_URL=http://localhost:5000

EXPO_PUBLIC_PREDICTION_ENDPOINT=
EXPO_PUBLIC_WEBSITE_URL=

# EXPO_OFFLINE=1
# EXPO_PUBLIC_FAST_SIGN_UP=1
# EXPO_PUBLIC_ENV=development

# Optional features
EXPO_PUBLIC_USE_AVATAR_CUSTOMIZATION=true

# Private Oky resources overlay. Set to 1 to clone periodtracker_resources-global
# into app/src/resources-global on the next yarn dev / yarn dev:app. Metro and
# app.config.js then route imports and asset paths through the private tree.
# Leave 0 (or unset) for the public build.
OKY_PRIVATE_RESOURCES=0
